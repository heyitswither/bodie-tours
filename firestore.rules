rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Private Bookings: Lock down entirely from client-side access
    match /bookings/{bookingId} {
      allow read, write: if false;
    }

    // 2. Public Inventory: Allow the booking widget to fetch availability for individual dates,
    // but block bulk collection listing queries (list) to prevent database harvesting/scraping.
    match /public/{date} {
      allow get: if true;
      allow list: if false;
      allow write: if false;
    }

    // 3. Configurations: Explicitly lock down config and email template collections
    match /config/{document=**} {
      allow read, write: if false;
    }

    match /email_templates/{document=**} {
      allow read, write: if false;
    }

    // 4. Global Fallback: Catch-all deny block
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
